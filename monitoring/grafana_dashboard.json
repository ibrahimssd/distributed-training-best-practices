{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "id": null,
  "title": "Distributed Training Monitor",
  "description": "GPU utilization, training throughput, and loss for DDP/FSDP/Hybrid jobs",
  "tags": ["ml", "training", "gpu"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Training Loss",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_loss_current{phase=\"train\"}",
          "legendFormat": "Train Loss"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Tokens per Second (Throughput)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_tokens_per_second",
          "legendFormat": "Tokens/sec"
        }
      ]
    },
    {
      "id": 3,
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "gpu_utilization_percent",
          "legendFormat": "GPU {{gpu_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent" }
      }
    },
    {
      "id": 4,
      "title": "GPU Memory Allocated (GB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "gpu_memory_allocated_gb",
          "legendFormat": "GPU {{gpu_id}} Allocated"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "gpu_memory_reserved_gb",
          "legendFormat": "GPU {{gpu_id}} Reserved"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decgbytes" }
      }
    },
    {
      "id": 5,
      "title": "Scaling Efficiency",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_scaling_efficiency * 100",
          "legendFormat": "Efficiency %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "yellow", "value": 70 },
              { "color": "green",  "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Learning Rate",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_learning_rate",
          "legendFormat": "LR"
        }
      ]
    },
    {
      "id": 7,
      "title": "Gradient Norm",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_gradient_norm",
          "legendFormat": "Grad Norm"
        }
      ]
    },
    {
      "id": 8,
      "title": "Checkpoints Saved",
      "type": "stat",
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "training_checkpoint_save_total",
          "legendFormat": "Checkpoints"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
